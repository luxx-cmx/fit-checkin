# ── 复制本文件为 .env 并填入真实值（.env 不会提交到 Git）──
# Docker Compose 会自动读取同目录下的 .env

# PostgreSQL
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme
POSTGRES_DB=changeme

# JWT 签名密钥（生产环境请换成长随机字符串）
JWT_SECRET=please-change-me-to-a-long-random-string

# 火山方舟 / 豆包视觉模型（服务端使用，禁止暴露到 NEXT_PUBLIC_*）
ARK_API_KEY=please-change-me
ARK_MODEL=doubao-seed-1-6-vision-250815
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/responses
